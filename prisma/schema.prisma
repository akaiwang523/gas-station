generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique @db.VarChar(50)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  name         String    @db.VarChar(50)
  role         UserRole  @default(STAFF)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  orders       Order[]
  payments     Payment[]
  @@map("users")
}

enum UserRole {
  ADMIN
  STAFF
  DRIVER
}

model Customer {
  id             Int              @id @default(autoincrement())
  name           String           @db.VarChar(100)
  phone          String           @db.VarChar(20)
  phone2         String?          @map("phone2") @db.VarChar(20)
  address        String           @db.VarChar(200)
  district       String?          @db.VarChar(50)
  gasType        GasType          @default(BOTTLED_20KG) @map("gas_type")
  cylinderSize   Int              @default(20) @map("cylinder_size")
  cylindersHeld  Int              @default(0) @map("cylinders_held")
  deposit        Decimal          @default(0) @db.Decimal(10, 2)
  priceOverride  Decimal?         @map("price_override") @db.Decimal(10, 2)
  deliveryCycle  DeliveryCycle    @default(ON_CALL) @map("delivery_cycle")
  deliveryDay    Int?             @map("delivery_day")
  note           String?          @db.Text
  status         CustomerStatus   @default(ACTIVE)
  lastDelivery   DateTime?        @map("last_delivery")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  contacts       CustomerContact[]
  priceHistory   PriceOverride[]
  arBalance      ArBalance?
  orders         Order[]
  @@index([phone])
  @@index([status])
  @@index([district])
  @@map("customers")
}

enum GasType {
  BOTTLED_20KG
  BOTTLED_16KG
  BOTTLED_4KG
  PIPED
}

enum DeliveryCycle {
  ON_CALL
  MONTHLY_FIXED
  FLOW_METER
  WEEKLY
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model CustomerContact {
  id         Int      @id @default(autoincrement())
  customerId Int      @map("customer_id")
  name       String   @db.VarChar(50)
  phone      String   @db.VarChar(20)
  relation   String?  @db.VarChar(30)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  @@map("customer_contacts")
}

model PriceOverride {
  id            Int       @id @default(autoincrement())
  customerId    Int       @map("customer_id")
  price         Decimal   @db.Decimal(10, 2)
  reason        String?   @db.VarChar(100)
  effectiveDate DateTime  @map("effective_date") @db.Date
  createdAt     DateTime  @default(now()) @map("created_at")
  customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  @@map("price_overrides")
}

model ArBalance {
  id             Int       @id @default(autoincrement())
  customerId     Int       @unique @map("customer_id")
  amountOwed     Decimal   @default(0) @map("amount_owed") @db.Decimal(10, 2)
  cylindersOwed  Int       @default(0) @map("cylinders_owed")
  lastPayment    DateTime? @map("last_payment")
  memo           String?   @db.VarChar(200)
  updatedAt      DateTime  @updatedAt @map("updated_at")
  customer       Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  @@map("ar_balances")
}

model Order {
  id           Int         @id @default(autoincrement())
  customerId   Int         @map("customer_id")
  driverId     Int?        @map("driver_id")
  quantity     Int
  unitPrice    Decimal     @map("unit_price") @db.Decimal(10, 2)
  totalAmount  Decimal     @map("total_amount") @db.Decimal(10, 2)
  status       OrderStatus @default(PENDING)
  note         String?     @db.VarChar(200)
  deliveredAt  DateTime?   @map("delivered_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  customer     Customer    @relation(fields: [customerId], references: [id])
  driver       User?       @relation(fields: [driverId], references: [id])
  payments     Payment[]
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  ASSIGNED
  DELIVERING
  DELIVERED
  CANCELLED
}

model Payment {
  id          Int           @id @default(autoincrement())
  orderId     Int           @map("order_id")
  collectedBy Int           @map("collected_by")
  amount      Decimal       @db.Decimal(10, 2)
  method      PaymentMethod @default(CASH)
  note        String?       @db.VarChar(200)
  paidAt      DateTime      @default(now()) @map("paid_at")
  order       Order         @relation(fields: [orderId], references: [id])
  collector   User          @relation(fields: [collectedBy], references: [id])
  @@map("payments")
}

enum PaymentMethod {
  CASH
  TRANSFER
  LINE_PAY
}
